{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/intentos/bl2-evidence-disposition.schema.json",
  "title": "IntentOS BL2 Evidence Disposition",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "requirementId",
    "packId",
    "evidenceType",
    "requirement",
    "disposition",
    "selectedProfiles",
    "scope",
    "basis",
    "projectEvidence",
    "reviewTriggers",
    "determinedBy"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "INTENTOS_BL2_DISPOSITION"
    },
    "requirementId": {
      "type": "string",
      "pattern": "^bl2:[a-z0-9-]+:[a-z0-9-]+:[a-z0-9-]+$"
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*-industrial$"
    },
    "evidenceType": {
      "type": "string",
      "minLength": 2
    },
    "requirement": {
      "type": "string",
      "minLength": 5
    },
    "disposition": {
      "const": "NOT_APPLICABLE"
    },
    "selectedProfiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "scope": {
      "type": "string",
      "minLength": 20
    },
    "basis": {
      "type": "string",
      "minLength": 30
    },
    "projectEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "claim"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "claim": {
            "type": "string",
            "minLength": 20
          }
        },
        "additionalProperties": false
      }
    },
    "reviewTriggers": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "enum": [
          "PROFILE_CHANGE",
          "PROJECT_SCOPE_CHANGE",
          "REQUIREMENT_CHANGE",
          "PROJECT_EVIDENCE_CHANGE"
        ]
      },
      "allOf": [
        { "contains": { "const": "PROFILE_CHANGE" } },
        { "contains": { "const": "PROJECT_SCOPE_CHANGE" } },
        { "contains": { "const": "REQUIREMENT_CHANGE" } }
      ]
    },
    "determinedBy": {
      "const": "CODEX_PROJECT_EVIDENCE"
    }
  },
  "additionalProperties": false
}
