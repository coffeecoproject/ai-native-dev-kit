{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/intentos/industrial-pack.schema.json",
  "title": "IntentOS Industrial Pack",
  "type": "object",
  "required": [
    "schemaVersion",
    "packVersion",
    "minimumIntentOSVersion",
    "lastReviewedAt",
    "stabilityNotes",
    "id",
    "type",
    "displayName",
    "status",
    "appliesToProfiles",
    "compatiblePacks",
    "conflictsWith",
    "requiredBaselines",
    "requiredExecutionDocs",
    "requiredAuditDocs",
    "requiredChecklists",
    "requiredTemplates",
    "riskMappings",
    "taskLevelEscalation",
    "requiredEvidence",
    "humanApprovalRequiredFor",
    "maturity"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "packVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "minimumIntentOSVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "lastReviewedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "stabilityNotes": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-industrial$"
    },
    "type": {
      "enum": ["primary-platform", "capability", "risk-overlay"]
    },
    "displayName": {
      "type": "string"
    },
    "status": {
      "enum": ["draft", "candidate", "stable", "deprecated", "retired"]
    },
    "appliesToProfiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "compatiblePacks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conflictsWith": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredBaselines": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "requiredExecutionDocs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "requiredAuditDocs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "requiredChecklists": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "requiredTemplates": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "riskMappings": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "taskLevelEscalation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["when", "minTaskLevel"],
        "properties": {
          "when": {
            "type": "array",
            "items": { "type": "string" }
          },
          "minTaskLevel": {
            "enum": ["L0", "L1", "L2", "L3"]
          }
        }
      }
    },
    "requiredEvidence": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "humanApprovalRequiredFor": {
      "type": "array",
      "items": { "type": "string" }
    },
    "maturity": {
      "type": "object",
      "required": [
        "stage",
        "stageReason",
        "lastMaturityReviewAt",
        "reviewedBy",
        "evidenceDocs",
        "evidenceSummary",
        "missingEvidenceBeforeCandidate",
        "missingEvidenceBeforeStable",
        "promotionCriteria",
        "demotionTriggers",
        "knownLimitations"
      ],
      "properties": {
        "stage": {
          "enum": ["draft", "candidate", "stable", "deprecated", "retired"]
        },
        "stageReason": {
          "type": "string",
          "minLength": 1
        },
        "lastMaturityReviewAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reviewedBy": {
          "type": "string",
          "minLength": 1
        },
        "evidenceDocs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 6
        },
        "evidenceSummary": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "missingEvidenceBeforeCandidate": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "missingEvidenceBeforeStable": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "promotionCriteria": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "demotionTriggers": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "knownLimitations": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
