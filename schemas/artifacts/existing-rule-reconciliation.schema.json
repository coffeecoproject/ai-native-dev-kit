{
  "schemaVersion": "1.110.0",
  "artifactType": "existing_rule_reconciliation_report",
  "required": [
    "schema_version",
    "evidence_profile",
    "artifact_type",
    "report_type",
    "project_state",
    "can_codex_write_now",
    "can_recommend_apply_plan",
    "can_recommend_apply_plan_now",
    "can_recommend_apply_plan_after_human_review",
    "reconciliation_authority",
    "business_authority",
    "production_authority",
    "requires_human_approval_before_apply",
    "existing_rule_source",
    "intentos_reference_source",
    "rule_reconciliation_coverage",
    "reconciliation_items",
    "protected_constraints",
    "release_production_gaps",
    "conflicts",
    "native_adoption_decision",
    "proposed_next_steps",
    "boundary",
    "outcome"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.69.2", "1.110.0"] },
    "evidence_profile": { "type": "string", "enum": ["existing-rule-reconciliation-1.69.2", "existing-rule-reconciliation-1.110.0"] },
    "artifact_type": { "type": "string", "enum": ["existing_rule_reconciliation_report"] },
    "report_type": { "type": "string", "enum": ["EXISTING_RULE_RECONCILIATION"] },
    "project_state": { "type": "string" },
    "can_codex_write_now": { "type": "string", "enum": ["No"] },
    "can_recommend_apply_plan": { "type": "string", "enum": ["Yes", "NoUntilBlockResolved"] },
    "can_recommend_apply_plan_now": { "type": "string", "enum": ["Yes", "No"] },
    "can_recommend_apply_plan_after_human_review": { "type": "string", "enum": ["Yes"] },
    "reconciliation_authority": { "type": "string", "enum": ["RECOMMENDATION_ONLY"] },
    "business_authority": { "type": "string", "enum": ["PROJECT_OWNED"] },
    "production_authority": { "type": "string", "enum": ["HUMAN_OR_EXTERNAL_SYSTEM"] },
    "requires_human_approval_before_apply": { "type": "string", "enum": ["Yes"] },
    "existing_rule_source": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_ref", "surface", "summary", "authority"],
        "properties": {
          "rule_ref": { "type": "string" },
          "surface": { "type": "string" },
          "summary": { "type": "string" },
          "authority": { "type": "string" }
        }
      }
    },
    "intentos_reference_source": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reference_ref", "surface", "summary", "authority"],
        "properties": {
          "reference_ref": { "type": "string" },
          "surface": { "type": "string" },
          "summary": { "type": "string" },
          "authority": { "type": "string" }
        }
      }
    },
    "rule_reconciliation_coverage": {
      "type": "object",
      "required": [
        "total_extracted_rules",
        "reconciled_rules",
        "omitted_rules",
        "truncation_warning",
        "blocks_selected_native_adoption"
      ],
      "properties": {
        "total_extracted_rules": { "type": "integer" },
        "reconciled_rules": { "type": "integer" },
        "omitted_rules": { "type": "integer" },
        "truncation_warning": { "type": "string" },
        "blocks_selected_native_adoption": { "type": "string", "enum": ["Yes", "No"] }
      }
    },
    "reconciliation_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "existing_rule_ref",
          "intentos_reference_ref",
          "surface",
          "surface_authority",
          "allowed_outcomes",
          "outcome",
          "reason",
          "risk_surfaces",
          "human_decision_required",
          "requires_apply_chain",
          "can_replace_existing_rule",
          "target_action"
        ],
        "properties": {
          "item_id": { "type": "string" },
          "existing_rule_ref": { "type": "string" },
          "intentos_reference_ref": { "type": "string" },
          "surface": {
            "type": "string",
            "enum": [
              "ENGINEERING_BASELINE",
              "RELEASE_PRODUCTION",
              "PRODUCTION_CONTROL",
              "PROTECTED_CONSTRAINT",
              "WORKFLOW_RULE",
              "UNKNOWN_AUTHORITY"
            ]
          },
          "surface_authority": {
            "type": "string",
            "enum": ["PROJECT_OWNED", "INTENTOS_REFERENCE", "HUMAN_OR_EXTERNAL"]
          },
          "allowed_outcomes": { "type": "array" },
          "outcome": {
            "type": "string",
            "enum": [
              "KEEP_EXISTING",
              "ADOPT_INTENTOS",
              "MERGE",
              "NEEDS_HUMAN_DECISION",
              "NO_INTENTOS_MATCH",
              "NO_EXISTING_RULE",
              "CONFLICT_HIGH_RISK",
              "UNKNOWN_AUTHORITY",
              "GAP_SUGGESTION"
            ]
          },
          "reason": { "type": "string" },
          "merge_reason": { "type": "string" },
          "preserved_existing_terms": { "type": "array" },
          "added_intentos_terms": { "type": "array" },
          "risk_surfaces": { "type": "array" },
          "human_decision_required": { "type": "string", "enum": ["Yes", "No"] },
          "requires_apply_chain": { "type": "string", "enum": ["Yes"] },
          "can_replace_existing_rule": { "type": "string", "enum": ["No"] },
          "target_action": { "type": "string" }
          ,"control_effectiveness_required": { "enum": ["Yes", "No"] }
          ,"control_claim_refs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "protected_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "surface", "owner", "authority", "human_decision_required", "handling"],
        "properties": {
          "item_id": { "type": "string" },
          "surface": { "type": "string" },
          "owner": { "type": "string" },
          "authority": { "type": "string" },
          "human_decision_required": { "type": "string", "enum": ["Yes", "No"] },
          "handling": { "type": "string" }
        }
      }
    },
    "release_production_gaps": { "type": "array" },
    "conflicts": { "type": "array" },
    "native_adoption_decision": {
      "type": "object",
      "required": [
        "recommendation",
        "migration_depth",
        "confidence",
        "can_codex_write_now",
        "default_path",
        "preserve",
        "merge",
        "replace",
        "blocked",
        "human_confirmation"
      ],
      "properties": {
        "recommendation": {
          "type": "string",
          "enum": [
            "READ_ONLY_DIAGNOSIS",
            "DOCS_BRIDGE",
            "SELECTED_NATIVE_ADOPTION",
            "BLOCKED_NEEDS_OWNER",
            "BLOCKED_BY_DIRTY_WORKTREE"
          ]
        },
        "migration_depth": { "type": "string" },
        "confidence": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "can_codex_write_now": { "type": "string", "enum": ["No"] },
        "default_path": { "type": "string" },
        "preserve": { "type": "array" },
        "merge": { "type": "array" },
        "replace": { "type": "array" },
        "blocked": { "type": "array" },
        "human_confirmation": { "type": "string" }
      }
    },
    "proposed_next_steps": { "type": "array" },
    "boundary": {
      "type": "object",
      "required": [
        "writesTargetFiles",
        "authorizesTargetFileWrites",
        "approvesGovernanceReplacement",
        "approvesImplementation",
        "approvesReleaseOrProduction",
        "modifiesCiOrHooks"
      ],
      "properties": {
        "writesTargetFiles": { "type": "string", "enum": ["No"] },
        "authorizesTargetFileWrites": { "type": "string", "enum": ["No"] },
        "approvesGovernanceReplacement": { "type": "string", "enum": ["No"] },
        "approvesImplementation": { "type": "string", "enum": ["No"] },
        "approvesReleaseOrProduction": { "type": "string", "enum": ["No"] },
        "modifiesCiOrHooks": { "type": "string", "enum": ["No"] }
      }
    },
    "outcome": {
      "type": "string",
      "enum": ["RECONCILIATION_RECORDED", "NEEDS_HUMAN_DECISION", "BLOCKED"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "schema_version": { "const": "1.110.0" } } },
      "then": {
        "properties": {
          "reconciliation_items": {
            "items": { "required": ["control_effectiveness_required", "control_claim_refs"] }
          }
        }
      }
    }
  ]
}
