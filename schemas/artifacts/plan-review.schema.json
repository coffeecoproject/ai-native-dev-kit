{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coffeecoproject.dev/schemas/plan-review.schema.json",
  "title": "Plan Review Gate Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "plan_review_ref",
    "plan_review_digest",
    "task_ref",
    "work_queue_item_ref",
    "work_queue_item_digest",
    "review_surface_analysis",
    "task_governance",
    "source_chain",
    "plan_ref",
    "plan_digest",
    "plan_task_match",
    "plan_review_state",
    "pre_implementation_review_prerequisite_satisfied",
    "ready_for_implementation_review",
    "implementation_authorized_by_this_report",
    "implementation_allowed_by_full_authority",
    "task_impact",
    "skip_review",
    "required_review_surfaces",
    "review_surface_matrix",
    "subagent_review_routing",
    "reviewed_surfaces",
    "findings",
    "revision_loop",
    "verification_command_review",
    "plain_user_summary",
    "plain_next_step",
    "technical_terms_required",
    "boundaries",
    "outcome"
  ],
  "properties": {
    "schema_version": { "enum": ["1.88.0", "1.108.0", "1.110.0", "1.113.0"] },
    "artifact_type": { "const": "plan_review" },
    "plan_review_ref": { "type": "string", "minLength": 1 },
    "plan_review_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "task_ref": { "type": "string", "minLength": 1 },
    "intent": { "type": "string", "minLength": 1 },
    "intent_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "work_queue_item_ref": { "type": "string", "minLength": 1 },
    "work_queue_item_digest": { "type": "string", "minLength": 1 },
    "review_surface_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "digest", "source", "derived_by_plan_review", "current_task_match", "user_selected_surfaces"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "minLength": 1 },
        "source": { "enum": ["review_surface_card", "project_native_equivalent", "derived_plan_review_matrix", "N/A"] },
        "derived_by_plan_review": { "enum": ["Yes", "No"] },
        "current_task_match": { "enum": ["Yes", "No", "Unknown", "N/A"] },
        "user_selected_surfaces": { "enum": ["Yes", "No"] }
      }
    },
    "task_governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "digest", "task_ref", "task_impact", "plan_review_required", "current_task_match"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "minLength": 1 },
        "task_ref": { "type": "string", "minLength": 1 },
        "intent_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "task_impact": { "enum": ["LOW", "MEDIUM", "POSSIBLE_HIGH", "HIGH", "Unknown"] },
        "plan_review_required": { "enum": ["Yes", "No", "Unknown"] },
        "current_task_match": { "enum": ["Yes", "No", "Unknown", "N/A"] },
        "outcome": { "type": "string", "minLength": 1 },
        "required_before_implementation_review": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scope_check_required", "short_plan_required", "business_universe_coverage_required",
            "control_effectiveness_required", "business_rule_closure_required",
            "change_impact_coverage_required", "execution_plan_required", "verification_plan_required"
          ],
          "properties": {
            "scope_check_required": { "enum": ["Yes", "No"] },
            "short_plan_required": { "enum": ["Yes", "No"] },
            "business_universe_coverage_required": { "enum": ["Yes", "No", "Unknown"] },
            "control_effectiveness_required": { "enum": ["Yes", "No", "Unknown"] },
            "business_rule_closure_required": { "enum": ["Yes", "No"] },
            "change_impact_coverage_required": { "enum": ["Yes", "No"] },
            "execution_plan_required": { "enum": ["Yes", "No"] },
            "verification_plan_required": { "enum": ["Yes", "No"] }
          }
        },
        "required_before_completion_claim": {
          "type": "object",
          "additionalProperties": false,
          "required": ["test_evidence_required", "execution_assurance_required", "completion_evidence_required"],
          "properties": {
            "test_evidence_required": { "enum": ["Yes", "No"] },
            "execution_assurance_required": { "enum": ["Yes", "No"] },
            "completion_evidence_required": { "enum": ["Yes", "No"] }
          }
        },
        "obligations_valid": { "enum": ["Yes", "No"] }
      }
    },
    "business_universe_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required", "routing_result", "business_universe_ref", "business_universe_digest", "business_universe_state",
        "coverage_scenario_ids", "coverage_mapping_status", "scenario_review_status",
        "lifecycle_review_status", "provenance_review_status",
        "challenger_required", "challenger_status"
      ],
      "properties": {
        "required": { "enum": ["Yes", "No", "Unknown"] },
        "routing_result": { "enum": ["REQUIRED_WITH_EVIDENCE", "TECHNICAL_INSPECTION_REQUIRED", "NOT_REQUIRED_WITH_REASON"] },
        "business_universe_ref": { "type": "string", "minLength": 1 },
        "business_universe_digest": { "type": "string", "minLength": 1 },
        "business_universe_state": { "type": "string", "minLength": 1 },
        "coverage_scenario_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "coverage_mapping_status": { "enum": ["COMPLETE", "NOT_REQUIRED", "BLOCKED"] },
        "scenario_review_status": { "enum": ["COMPLETE", "NOT_REQUIRED", "BLOCKED"] },
        "lifecycle_review_status": { "enum": ["COMPLETE", "NOT_REQUIRED", "BLOCKED"] },
        "provenance_review_status": { "enum": ["COMPLETE", "NOT_REQUIRED", "BLOCKED"] },
        "challenger_required": { "enum": ["Yes", "No"] },
        "challenger_status": { "type": "string", "minLength": 1 }
      }
    },
    "control_effectiveness_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement", "status", "report_ref", "report_digest", "required_claim_ids",
        "assessment_outcome", "current_project_match", "current_task_match",
        "current_intent_match", "checker", "reason"
      ],
      "properties": {
        "requirement": { "enum": ["REQUIRED", "NOT_REQUIRED"] },
        "status": { "enum": ["VERIFIED", "BLOCKED", "NOT_REQUIRED"] },
        "report_ref": { "type": "string", "minLength": 1 },
        "report_digest": { "type": "string", "minLength": 1 },
        "required_claim_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "assessment_outcome": { "enum": ["CONTROL_PROVEN_EFFECTIVE", "CONTROL_PROVEN_PARTIAL", "CONTROL_NOT_PROVEN", "CONTROL_INVALID", "NOT_APPLICABLE_WITH_REASON"] },
        "current_project_match": { "enum": ["Yes", "No", "N/A"] },
        "current_task_match": { "enum": ["Yes", "No", "N/A"] },
        "current_intent_match": { "enum": ["Yes", "No", "N/A"] },
        "checker": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "plan_scenario_reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "plan_scenario_review_id", "source_coverage_scenario_ids", "reviewed_surfaces",
          "lifecycle_reviewed", "provenance_reviewed", "negative_or_reverse_reviewed", "review_state"
        ],
        "properties": {
          "plan_scenario_review_id": { "type": "string", "pattern": "^plan-scenario-review:[a-z0-9][a-z0-9._-]*$" },
          "source_coverage_scenario_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "reviewed_surfaces": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "lifecycle_reviewed": { "enum": ["Yes", "No"] },
          "provenance_reviewed": { "enum": ["Yes", "No"] },
          "negative_or_reverse_reviewed": { "enum": ["Yes", "No"] },
          "review_state": { "enum": ["REVIEWED", "BLOCKED"] }
        }
      }
    },
    "source_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_kind",
          "source_ref",
          "source_digest",
          "source_state",
          "current_task_match",
          "project_native_equivalent",
          "owner",
          "contradicts_plan"
        ],
        "properties": {
          "source_kind": { "type": "string", "minLength": 1 },
          "source_ref": { "type": "string", "minLength": 1 },
          "source_digest": { "type": "string", "minLength": 1 },
          "source_state": { "type": "string", "minLength": 1 },
          "current_task_match": { "enum": ["Yes", "No", "Unknown", "N/A"] },
          "project_native_equivalent": { "enum": ["Yes", "No"] },
          "owner": { "type": "string", "minLength": 1 },
          "contradicts_plan": { "enum": ["Yes", "No", "Unknown"] }
        }
      }
    },
    "plan_ref": { "type": "string", "minLength": 1 },
    "plan_digest": { "type": "string", "minLength": 1 },
    "plan_task_match": { "enum": ["Yes", "No", "Unknown", "N/A"] },
    "plan_content_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "scope_section_present", "boundaries_section_present",
        "implementation_sequence_present", "verification_section_present",
        "rollback_recovery_section_present", "concrete_target_refs",
        "implementation_step_count", "missing_requirements"
      ],
      "properties": {
        "status": { "enum": ["COMPLETE", "INCOMPLETE", "NOT_REQUIRED"] },
        "scope_section_present": { "enum": ["Yes", "No", "N/A"] },
        "boundaries_section_present": { "enum": ["Yes", "No", "N/A"] },
        "implementation_sequence_present": { "enum": ["Yes", "No", "N/A"] },
        "verification_section_present": { "enum": ["Yes", "No", "N/A"] },
        "rollback_recovery_section_present": { "enum": ["Yes", "No", "N/A"] },
        "concrete_target_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "implementation_step_count": { "type": "integer" },
        "missing_requirements": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "scope", "boundaries", "implementation_sequence",
              "verification", "rollback_recovery", "concrete_target_refs"
            ]
          }
        }
      }
    },
    "plan_review_state": {
      "enum": [
        "NO_PLAN_REQUIRED",
        "PLAN_REQUIRED",
        "PLAN_DRAFTED",
        "PLAN_REVIEW_REQUIRED",
        "PLAN_REVISION_REQUIRED",
        "PLAN_REVIEW_PASSED",
        "BLOCKED_BY_STALE_PLAN",
        "BLOCKED_BY_INCOMPLETE_REVIEW",
        "BLOCKED_BY_USER_DECISION",
        "BLOCKED_BY_REPEATED_PLAN_REVIEW_FAILURE",
        "PLAN_REVIEW_REQUIRED_WITH_TASK_GOVERNANCE_RECHECK"
      ]
    },
    "pre_implementation_review_prerequisite_satisfied": { "enum": ["Yes", "No"] },
    "ready_for_implementation_review": { "enum": ["Yes", "No"] },
    "implementation_authorized_by_this_report": { "enum": ["Yes", "No"] },
    "implementation_allowed_by_full_authority": { "enum": ["Yes", "No", "Unknown"] },
    "task_impact": { "enum": ["LOW", "MEDIUM", "POSSIBLE_HIGH", "HIGH", "Unknown"] },
    "skip_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skip_allowed", "skip_source", "skip_reason", "task_impact"],
      "properties": {
        "skip_allowed": { "enum": ["Yes", "No"] },
        "skip_source": { "type": "string", "minLength": 1 },
        "skip_reason": { "type": "string", "minLength": 1 },
        "task_impact": { "enum": ["LOW", "MEDIUM", "POSSIBLE_HIGH", "HIGH", "Unknown"] }
      }
    },
    "required_review_surfaces": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "review_surface_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface",
          "required",
          "required_before_implementation",
          "required_after_implementation",
          "reviewed",
          "source",
          "human_decision_needed",
          "finding_count",
          "blocking"
        ],
        "properties": {
          "surface": { "type": "string", "minLength": 1 },
          "required": { "enum": ["Yes", "No"] },
          "required_before_implementation": { "enum": ["Yes", "No"] },
          "required_after_implementation": { "enum": ["Yes", "No"] },
          "reviewed": { "enum": ["Yes", "No"] },
          "source": { "type": "string", "minLength": 1 },
          "human_decision_needed": { "enum": ["Yes", "No"] },
          "finding_count": { "type": "integer" },
          "blocking": { "enum": ["Yes", "No"] }
        }
      }
    },
    "subagent_review_routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subagent_review_recommended",
        "reason",
        "run_plan_required",
        "run_plan_ref",
        "all_subagents_read_only",
        "subagent_output_is_authority",
        "writer_subagent_used",
        "all_subagents_closed_or_skipped",
        "fallback_used",
        "fallback_reason"
      ],
      "properties": {
        "subagent_review_recommended": { "enum": ["Yes", "No"] },
        "reason": { "type": "string" },
        "run_plan_required": { "enum": ["Yes", "No"] },
        "run_plan_ref": { "type": "string", "minLength": 1 },
        "all_subagents_read_only": { "enum": ["Yes", "No", "N/A"] },
        "subagent_output_is_authority": { "enum": ["Yes", "No"] },
        "writer_subagent_used": { "enum": ["Yes", "No"] },
        "all_subagents_closed_or_skipped": { "enum": ["Yes", "No", "Unknown", "N/A"] },
        "fallback_used": { "enum": ["Yes", "No"] },
        "fallback_reason": { "type": "string" }
      }
    },
    "reviewed_surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["surface", "reviewed", "finding_count", "notes"],
        "properties": {
          "surface": { "type": "string", "minLength": 1 },
          "reviewed": { "enum": ["Yes", "No"] },
          "finding_count": { "type": "integer" },
          "notes": { "type": "string" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "surface",
          "summary",
          "required_action",
          "resolved",
          "accepted",
          "accepted_by_ref",
          "acceptance_reason",
          "acceptance_scope",
          "expires_at",
          "allowed_for_task_impact"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["P0", "P1", "P2", "P3"] },
          "surface": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "required_action": { "type": "string", "minLength": 1 },
          "resolved": { "enum": ["Yes", "No"] },
          "accepted": { "enum": ["Yes", "No"] },
          "accepted_by_ref": { "type": "string", "minLength": 1 },
          "acceptance_reason": { "type": "string", "minLength": 1 },
          "acceptance_scope": { "type": "string", "minLength": 1 },
          "expires_at": { "type": "string", "minLength": 1 },
          "allowed_for_task_impact": { "type": "string", "minLength": 1 }
        }
      }
    },
    "revision_loop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["round", "max_auto_rounds", "requires_revision", "previous_plan_digest", "rewrites_original_plan", "revised_plan_ref"],
      "properties": {
        "round": { "type": "integer" },
        "max_auto_rounds": { "type": "integer" },
        "requires_revision": { "enum": ["Yes", "No"] },
        "previous_plan_digest": { "type": "string", "minLength": 1 },
        "rewrites_original_plan": { "enum": ["Yes", "No"] },
        "revised_plan_ref": { "type": "string", "minLength": 1 }
      }
    },
    "verification_command_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands_reviewed",
        "commands_exist_in_project",
        "commands_are_project_native",
        "commands_target_required_behavior",
        "commands_executed_by_this_report",
        "requires_test_evidence_later",
        "fake_or_unstable_command_found",
        "notes"
      ],
      "properties": {
        "commands_reviewed": { "enum": ["Yes", "No"] },
        "commands_exist_in_project": { "enum": ["Yes", "No", "Unknown"] },
        "commands_are_project_native": { "enum": ["Yes", "No", "Unknown"] },
        "commands_target_required_behavior": { "enum": ["Yes", "No", "Unknown"] },
        "commands_executed_by_this_report": { "enum": ["Yes", "No"] },
        "requires_test_evidence_later": { "enum": ["Yes", "No"] },
        "fake_or_unstable_command_found": { "enum": ["Yes", "No"] },
        "working_directory_verified": { "enum": ["Yes", "No", "N/A"] },
        "all_commands_authoritative": { "enum": ["Yes", "No", "N/A"] },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "command", "kind", "executable_or_script_exists",
              "project_native", "working_directory_safe",
              "targets_required_behavior", "reason"
            ],
            "properties": {
              "command": { "type": "string", "minLength": 1 },
              "kind": { "enum": ["package_script", "node_script", "project_tool", "unsupported"] },
              "executable_or_script_exists": { "enum": ["Yes", "No"] },
              "project_native": { "enum": ["Yes", "No"] },
              "working_directory_safe": { "enum": ["Yes", "No"] },
              "targets_required_behavior": { "enum": ["Yes", "No"] },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "plain_user_summary": { "type": "string", "minLength": 1 },
    "plain_next_step": { "type": "string", "minLength": 1 },
    "technical_terms_required": { "enum": ["Yes", "No"] },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writes_target_files",
        "authorizes_implementation",
        "approves_commit_or_push",
        "approves_release_or_production",
        "executes_tests",
        "changes_production"
      ],
      "properties": {
        "writes_target_files": { "enum": ["Yes", "No"] },
        "authorizes_implementation": { "enum": ["Yes", "No"] },
        "approves_commit_or_push": { "enum": ["Yes", "No"] },
        "approves_release_or_production": { "enum": ["Yes", "No"] },
        "executes_tests": { "enum": ["Yes", "No"] },
        "changes_production": { "enum": ["Yes", "No"] }
      }
    },
    "outcome": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": { "properties": { "schema_version": { "const": "1.108.0" } } },
      "then": { "required": ["business_universe_binding", "plan_scenario_reviews"] }
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.110.0" } } },
      "then": { "required": ["business_universe_binding", "plan_scenario_reviews", "control_effectiveness_binding"] }
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.113.0" } } },
      "then": {
        "required": ["intent", "intent_digest", "business_universe_binding", "plan_scenario_reviews", "control_effectiveness_binding", "plan_content_review"],
        "properties": {
          "task_governance": {
            "required": [
              "intent_digest", "outcome", "required_before_implementation_review",
              "required_before_completion_claim", "obligations_valid"
            ]
          },
          "verification_command_review": {
            "required": ["working_directory_verified", "all_commands_authoritative", "commands"]
          }
        }
      }
    }
  ]
}
