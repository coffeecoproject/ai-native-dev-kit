{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coffeecoproject.dev/schemas/verification-runtime-plan.schema.json",
  "title": "Verification Runtime Plan",
  "type": "object",
  "schemaVersion": "1.102.0",
  "artifactType": "verification_runtime_plan",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "runtime_plan_ref",
    "runtime_plan_digest",
    "task_ref",
    "intent",
    "intent_digest",
    "task_tier",
    "task_governance_source",
    "verification_plan_source",
    "runtime_trust_level",
    "adapter_selection",
    "required_controls",
    "preflight_requirements",
    "resource_isolation_plan",
    "boundaries",
    "authority_binding",
    "outcome",
    "next_step"
  ],
  "properties": {
    "schema_version": { "enum": ["1.101.0", "1.102.0"] },
    "artifact_type": { "const": "verification_runtime_plan" },
    "runtime_plan_ref": { "type": "string", "minLength": 1 },
    "runtime_plan_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "task_ref": { "type": "string", "minLength": 1 },
    "intent": { "type": "string", "minLength": 1 },
    "intent_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "task_tier": { "enum": ["LOW", "MEDIUM", "POSSIBLE_HIGH", "HIGH"] },
    "task_governance_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "ref", "digest", "tier", "current_task_match"],
      "properties": {
        "status": { "enum": ["RECORDED", "DERIVED_CURRENT_INTENT", "BLOCKED"] },
        "ref": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "tier": { "enum": ["LOW", "MEDIUM", "POSSIBLE_HIGH", "HIGH"] },
        "current_task_match": { "enum": ["Yes", "No", "Unknown"] }
      }
    },
    "verification_plan_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "ref", "digest", "state", "current_task_match"],
      "properties": {
        "status": { "enum": ["RECORDED", "NOT_REQUIRED", "BLOCKED"] },
        "ref": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "minLength": 1 },
        "state": { "type": "string", "minLength": 1 },
        "current_task_match": { "enum": ["Yes", "No", "Unknown", "Not applicable"] }
      }
    },
    "runtime_trust_level": {
      "enum": [
        "SOURCE_OUTPUT_BINDING",
        "TARGETED_SERVICE_IDENTITY",
        "ISOLATED_RUNTIME",
        "BLOCKED_FOR_CLASSIFICATION"
      ]
    },
    "adapter_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "adapter_kind", "selected_by", "reason", "user_selection_required"],
      "properties": {
        "status": { "enum": ["SELECTED", "NOT_REQUIRED", "BLOCKED"] },
        "adapter_kind": {
          "enum": [
            "COMMAND_ONLY",
            "LOCAL_PROCESS",
            "DOCKER_CONTAINER",
            "KUBERNETES_WORKLOAD",
            "SERVERLESS_DEPLOYMENT",
            "STATIC_BUILD",
            "PROJECT_NATIVE",
            "UNRESOLVED"
          ]
        },
        "selected_by": { "const": "CODEX" },
        "reason": { "type": "string", "minLength": 1 },
        "user_selection_required": { "const": "No" },
        "contract_version": { "const": "1.102.0" },
        "contract_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "discovery_confidence": { "enum": ["OBSERVED", "DECLARED", "NOT_REQUIRED", "UNRESOLVED"] },
        "discovery_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["signal", "ref", "digest"],
            "properties": {
              "signal": { "type": "string", "minLength": 1 },
              "ref": { "type": "string", "pattern": "^file:[^\\s]+$" },
              "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
            }
          }
        },
        "alternative_adapters": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["LOCAL_PROCESS", "DOCKER_CONTAINER", "KUBERNETES_WORKLOAD", "SERVERLESS_DEPLOYMENT", "STATIC_BUILD", "PROJECT_NATIVE"] }
        },
        "supported_trust_levels": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["SOURCE_OUTPUT_BINDING", "TARGETED_SERVICE_IDENTITY", "ISOLATED_RUNTIME"] }
        },
        "required_identity_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "adapter_preflight_probes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "managed_resource_types": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "lifecycle_mode": { "enum": ["OBSERVE_AND_PLAN_ONLY", "BLOCKED"] },
        "starts_or_stops_runtime": { "const": "No" },
        "creates_or_deletes_resources": { "const": "No" }
      }
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["control", "requirement", "reason"],
        "properties": {
          "control": {
            "enum": [
              "SOURCE_IDENTITY",
              "OUTPUT_BINDING",
              "SERVICE_IDENTITY",
              "DATA_ISOLATION",
              "SESSION_ISOLATION",
              "RESOURCE_OWNERSHIP",
              "CLEANUP_PROOF",
              "POSITIVE_NEGATIVE_PATHS"
            ]
          },
          "requirement": { "enum": ["REQUIRED", "CONDITIONAL", "NOT_REQUIRED", "BLOCKED"] },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "preflight_requirements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["probe", "required", "expected_result", "reason"],
        "properties": {
          "probe": {
            "enum": [
              "SOURCE_IDENTITY",
              "WORKTREE_STATE",
              "OLD_PROCESS",
              "PORT_CONFLICT",
              "SENSITIVE_ENVIRONMENT",
              "DATA_IDENTITY",
              "SESSION_RESIDUE",
              "PRODUCTION_RESOURCE_GUARD"
            ]
          },
          "required": { "enum": ["Yes", "No"] },
          "expected_result": { "const": "PASS" },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "resource_isolation_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource_type", "requirement", "isolation_strategy", "production_allowed", "ownership_required", "reason"],
        "properties": {
          "resource_type": { "enum": ["SERVICE", "DATABASE", "CACHE", "SESSION", "QUEUE", "OBJECT_STORE", "OTHER"] },
          "requirement": { "enum": ["REQUIRED", "CONDITIONAL", "NOT_REQUIRED"] },
          "isolation_strategy": { "enum": ["RUN_SCOPED_INSTANCE", "RUN_SCOPED_NAMESPACE", "READ_ONLY_BINDING", "NOT_REQUIRED", "PROJECT_NATIVE_ISOLATION"] },
          "production_allowed": { "const": "No" },
          "ownership_required": { "enum": ["Yes", "No"] },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "starts_services",
        "executes_tests",
        "creates_or_deletes_resources",
        "changes_production",
        "asks_user_for_technical_choices",
        "approves_implementation_release_or_production",
        "proves_real_environment_behavior"
      ],
      "properties": {
        "starts_services": { "const": "No" },
        "executes_tests": { "const": "No" },
        "creates_or_deletes_resources": { "const": "No" },
        "changes_production": { "const": "No" },
        "asks_user_for_technical_choices": { "const": "No" },
        "approves_implementation_release_or_production": { "const": "No" },
        "proves_real_environment_behavior": { "const": "No" }
      }
    },
    "authority_binding": { "$ref": "#/$defs/authorityBinding" },
    "outcome": { "enum": ["RUNTIME_PLAN_READY", "RUNTIME_PLAN_BLOCKED"] },
    "next_step": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "authorityBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding_version", "project", "task", "sources"],
      "properties": {
        "binding_version": { "const": "1.91.0" },
        "project": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "fingerprint", "revision"],
          "properties": {
            "kind": { "enum": ["GIT", "NON_GIT"] },
            "fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
            "revision": { "type": "string", "minLength": 1 }
          }
        },
        "task": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_ref", "intent_digest"],
          "properties": {
            "task_ref": { "type": "string", "minLength": 1 },
            "intent_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref", "relative_path", "raw_file_digest"],
            "properties": {
              "ref": { "type": "string", "minLength": 1 },
              "relative_path": { "type": "string", "minLength": 1 },
              "raw_file_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
            }
          }
        }
      }
    }
  }
}
