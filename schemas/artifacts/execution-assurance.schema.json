{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coffeecoproject.dev/schemas/execution-assurance.schema.json",
  "title": "Execution Assurance Report Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "execution_kind",
    "task_ref",
    "intent_digest",
    "assurance_state",
    "can_claim_done",
    "can_codex_write_now",
    "intent_lock",
    "completion_contract",
    "planned_impact_map",
    "execution_plan",
    "actual_diff",
    "evidence_bindings",
    "review",
    "patch_assessment",
    "source_systems",
    "pending_human_decisions",
    "forbidden_claims",
    "boundary",
    "outcome"
  ],
  "properties": {
    "schema_version": {
      "enum": ["1.74.0", "1.104.0", "1.108.0", "1.110.0", "1.113.0"]
    },
    "artifact_type": {
      "const": "execution_assurance_report"
    },
    "execution_kind": {
      "enum": [
        "FEATURE_IMPLEMENTATION",
        "BUG_FIX",
        "SAFE_PATCH",
        "CONTROLLED_PATCH",
        "ADOPTION_MIGRATION",
        "BASELINE_SETUP",
        "DOCUMENT_GOVERNANCE",
        "RELEASE_PREPARATION",
        "WORKFLOW_CAPABILITY",
        "UNKNOWN"
      ]
    },
    "task_ref": {
      "type": "string",
      "minLength": 1
    },
    "intent_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "authority_binding": {
      "$ref": "#/$defs/authorityBinding"
    },
    "assurance_state": {
      "$ref": "#/$defs/assuranceState"
    },
    "can_claim_done": {
      "enum": [
        "Yes",
        "No"
      ]
    },
    "can_codex_write_now": {
      "const": "No"
    },
    "intent_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_intent",
        "normalized_intent",
        "in_scope",
        "out_of_scope"
      ],
      "properties": {
        "user_intent": {
          "type": "string",
          "minLength": 1
        },
        "normalized_intent": {
          "type": "string",
          "minLength": 1
        },
        "in_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "completion_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criteria"
      ],
      "properties": {
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/criterion"
          }
        }
      }
    },
    "planned_impact_map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfaces"
      ],
      "properties": {
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surface"
          }
        }
      }
    },
    "execution_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_ref",
        "planned_target_paths",
        "risk_classification",
        "approval_refs",
        "restore_strategy"
      ],
      "properties": {
        "plan_ref": {
          "type": "string",
          "minLength": 1
        },
        "planned_target_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_classification": {
          "type": "string",
          "minLength": 1
        },
        "approval_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "restore_strategy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "actual_diff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diff_source",
        "changed_files",
        "unexpected_files",
        "target_diff_status"
      ],
      "properties": {
        "diff_source": {
          "type": "string",
          "minLength": 1
        },
        "base_revision": {
          "type": "string",
          "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64}|N/A)$"
        },
        "changed_files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "unexpected_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target_diff_status": {
          "enum": [
            "MATCHED_PLAN",
            "REQUIRES_EXPLICIT_EXECUTION_PLAN",
            "UNCHANGED_FOR_READ_ONLY",
            "UNCHANGED_FOR_READ_ONLY_OR_MATCHED_FOR_WRITE",
            "UNEXPECTED_DIFF",
            "UNKNOWN"
          ]
        }
      }
    },
    "evidence_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidenceBinding"
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_required",
        "review_refs",
        "all_reviewers_closed"
      ],
      "properties": {
        "review_required": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "review_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "all_reviewers_closed": {
          "enum": [
            "Yes",
            "No"
          ]
        }
      }
    },
    "patch_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "reason"
      ],
      "properties": {
        "state": {
          "enum": [
            "NOT_A_PATCH",
            "SAFE_PATCH",
            "CONTROLLED_PATCH",
            "PATCH_SMELL",
            "BLOCKED_PATCH"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_systems": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceSystem"
      }
    },
    "runtime_trust_binding": {
      "$ref": "#/$defs/runtimeTrustBinding"
    },
    "business_universe_binding": {
      "$ref": "#/$defs/businessUniverseBinding"
    },
    "control_effectiveness_binding": {
      "$ref": "#/$defs/controlEffectivenessBinding"
    },
    "scenario_assurance_map": {
      "type": "array",
      "items": { "$ref": "#/$defs/scenarioAssurance" }
    },
    "task_entry_binding": {
      "$ref": "#/$defs/taskEntryBinding"
    },
    "planning_closure_binding": {
      "$ref": "#/$defs/planningClosureBinding"
    },
    "pre_write_revalidation": {
      "$ref": "#/$defs/preWriteRevalidation"
    },
    "pending_human_decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writes_target_files",
        "authorizes_target_file_writes",
        "approves_implementation_beyond_recorded_scope",
        "approves_commit_or_push",
        "approves_release_or_production",
        "replaces_source_systems",
        "proves_product_correctness",
        "transfers_project_authority_to_intentos"
      ],
      "properties": {
        "writes_target_files": {
          "const": "No"
        },
        "authorizes_target_file_writes": {
          "const": "No"
        },
        "approves_implementation_beyond_recorded_scope": {
          "const": "No"
        },
        "approves_commit_or_push": {
          "const": "No"
        },
        "approves_release_or_production": {
          "const": "No"
        },
        "replaces_source_systems": {
          "const": "No"
        },
        "proves_product_correctness": {
          "const": "No"
        },
        "transfers_project_authority_to_intentos": {
          "const": "No"
        }
      }
    },
    "outcome": {
      "$ref": "#/$defs/assuranceState"
    },
    "plan_review_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "plan_review_ref",
        "plan_review_digest",
        "plan_review_state",
        "plan_ref",
        "plan_digest",
        "task_ref",
        "current_task_match",
        "ready_for_implementation_review",
        "implementation_authorized_by_this_report",
        "reason"
      ],
      "properties": {
        "required": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "plan_review_ref": {
          "type": "string",
          "minLength": 1
        },
        "plan_review_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "plan_review_state": {
          "enum": [
            "NO_PLAN_REQUIRED",
            "PLAN_REQUIRED",
            "PLAN_DRAFTED",
            "PLAN_REVIEW_REQUIRED",
            "PLAN_REVISION_REQUIRED",
            "PLAN_REVIEW_PASSED",
            "BLOCKED_BY_STALE_PLAN",
            "BLOCKED_BY_INCOMPLETE_REVIEW",
            "BLOCKED_BY_USER_DECISION",
            "BLOCKED_BY_REPEATED_PLAN_REVIEW_FAILURE",
            "PLAN_REVIEW_REQUIRED_WITH_TASK_GOVERNANCE_RECHECK"
          ]
        },
        "plan_ref": {
          "type": "string",
          "minLength": 1
        },
        "plan_digest": {
          "type": "string",
          "minLength": 1
        },
        "task_ref": {
          "type": "string",
          "minLength": 1
        },
        "current_task_match": {
          "enum": [
            "Yes",
            "No",
            "Unknown",
            "N/A"
          ]
        },
        "ready_for_implementation_review": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "implementation_authorized_by_this_report": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "schema_version": { "const": "1.108.0" } } },
      "then": { "required": ["business_universe_binding", "scenario_assurance_map", "runtime_trust_binding", "authority_binding"] }
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.110.0" } }, "required": ["schema_version"] },
      "then": { "required": ["business_universe_binding", "scenario_assurance_map", "runtime_trust_binding", "control_effectiveness_binding", "planning_closure_binding", "authority_binding"] }
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.113.0" } }, "required": ["schema_version"] },
      "then": { "required": ["business_universe_binding", "scenario_assurance_map", "runtime_trust_binding", "control_effectiveness_binding", "planning_closure_binding", "pre_write_revalidation", "authority_binding"] }
    },
    {
      "if": {
        "properties": {
          "schema_version": { "const": "1.113.0" },
          "actual_diff": {
            "properties": { "diff_source": { "const": "git:cached" } },
            "required": ["diff_source"]
          }
        },
        "required": ["schema_version", "actual_diff"]
      },
      "then": {
        "properties": {
          "actual_diff": { "required": ["base_revision"] }
        }
      }
    },
    {
      "if": {
        "properties": {
          "schema_version": { "const": "1.113.0" },
          "assurance_state": { "const": "VERIFIED_DONE" }
        },
        "required": ["schema_version", "assurance_state"]
      },
      "then": {
        "properties": {
          "pending_human_decisions": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "schema_version": { "const": "1.113.0" },
          "execution_kind": { "const": "FEATURE_IMPLEMENTATION" },
          "assurance_state": { "const": "VERIFIED_DONE" }
        },
        "required": ["schema_version", "execution_kind", "assurance_state"]
      },
      "then": {
        "properties": {
          "actual_diff": {
            "properties": {
              "diff_source": { "const": "git:working-tree" },
              "changed_files": { "minItems": 1 }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "preWriteRevalidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "checked_at", "project_identity", "planning_closure_ref", "planning_closure_core_digest",
        "execution_entry_contract_digest", "source_revision_digest", "source_git_commit", "candidate_base_revision",
        "planned_target_paths_digest", "actual_changed_paths_digest", "result", "reason"
      ],
      "properties": {
        "status": { "enum": ["VERIFIED", "BLOCKED"] },
        "checked_at": { "type": "string", "minLength": 1 },
        "project_identity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "fingerprint", "revision"],
          "properties": {
            "kind": { "enum": ["GIT", "NON_GIT"] },
            "fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
            "revision": { "type": "string", "minLength": 1 }
          }
        },
        "planning_closure_ref": { "type": "string", "minLength": 1 },
        "planning_closure_core_digest": { "type": "string", "minLength": 1 },
        "execution_entry_contract_digest": { "type": "string", "minLength": 1 },
        "source_revision_digest": { "type": "string", "minLength": 1 },
        "source_git_commit": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64}|N/A)$" },
        "candidate_base_revision": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64}|N/A)$" },
        "planned_target_paths_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "actual_changed_paths_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "result": { "enum": ["PRE_WRITE_SNAPSHOT_REPLAYED", "BLOCKED"] },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "planningClosureBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement", "status", "planning_closure_ref", "planning_closure_report_digest",
        "planning_closure_core_digest", "planning_closure_outcome", "task_ref", "intent_digest",
        "current_project_match", "current_task_match", "current_intent_match",
        "execution_entry_contract_digest", "contract_non_authorizing",
        "requires_pre_write_revalidation", "checker", "reason"
      ],
      "properties": {
        "requirement": { "const": "REQUIRED" },
        "status": { "enum": ["VERIFIED", "BLOCKED"] },
        "planning_closure_ref": { "type": "string", "minLength": 1 },
        "planning_closure_report_digest": { "type": "string", "minLength": 1 },
        "planning_closure_core_digest": { "type": "string", "minLength": 1 },
        "planning_closure_outcome": { "enum": ["PLANNING_READY", "PLANNING_IN_PROGRESS", "PLANNING_INPUT_NEEDED", "PLANNING_DISCOVERY_NEEDED", "PLANNING_BLOCKED", "PLANNING_INVALID"] },
        "task_ref": { "type": "string", "minLength": 1 },
        "intent_digest": { "type": "string", "minLength": 1 },
        "current_project_match": { "enum": ["Yes", "No"] },
        "current_task_match": { "enum": ["Yes", "No"] },
        "current_intent_match": { "enum": ["Yes", "No"] },
        "execution_entry_contract_digest": { "type": "string", "minLength": 1 },
        "contract_non_authorizing": { "enum": ["Yes", "No"] },
        "requires_pre_write_revalidation": { "enum": ["Yes", "No"] },
        "checker": { "const": "scripts/check-planning-closure.mjs --require-ready + scripts/check-execution-entry-contract.mjs --require-contract" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "controlEffectivenessBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement", "status", "report_ref", "report_digest", "required_claim_ids", "assessment_outcome", "current_project_match", "current_task_match", "current_intent_match", "checker", "reason"],
      "properties": {
        "requirement": { "enum": ["REQUIRED", "NOT_REQUIRED"] },
        "status": { "enum": ["VERIFIED", "BLOCKED", "NOT_REQUIRED"] },
        "report_ref": { "type": "string", "minLength": 1 },
        "report_digest": { "type": "string", "minLength": 1 },
        "required_claim_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "assessment_outcome": { "enum": ["CONTROL_PROVEN_EFFECTIVE", "CONTROL_PROVEN_PARTIAL", "CONTROL_NOT_PROVEN", "CONTROL_INVALID", "NOT_APPLICABLE_WITH_REASON"] },
        "current_project_match": { "enum": ["Yes", "No", "N/A"] },
        "current_task_match": { "enum": ["Yes", "No", "N/A"] },
        "current_intent_match": { "enum": ["Yes", "No", "N/A"] },
        "checker": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "businessUniverseBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required", "routing_result", "business_universe_ref", "business_universe_digest",
        "business_universe_state", "coverage_scenario_ids", "coverage_mapping_status"
      ],
      "properties": {
        "required": { "enum": ["Yes", "No", "Unknown"] },
        "routing_result": { "enum": ["REQUIRED_WITH_EVIDENCE", "TECHNICAL_INSPECTION_REQUIRED", "NOT_REQUIRED_WITH_REASON"] },
        "business_universe_ref": { "type": "string", "minLength": 1 },
        "business_universe_digest": { "type": "string", "minLength": 1 },
        "business_universe_state": { "type": "string", "minLength": 1 },
        "coverage_scenario_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "coverage_mapping_status": { "enum": ["COMPLETE", "NOT_REQUIRED", "BLOCKED"] }
      }
    },
    "scenarioAssurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coverage_scenario_id", "required_obligation_ids", "covered_obligation_ids",
        "test_evidence_ids", "required_proof_strength", "test_evidence_state", "assurance_state"
      ],
      "properties": {
        "coverage_scenario_id": { "type": "string", "pattern": "^coverage-scenario:[a-f0-9]{24}$" },
        "required_obligation_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "covered_obligation_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "test_evidence_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "required_proof_strength": { "enum": ["STRUCTURAL_SOURCE_PROOF", "PROJECT_NATIVE_BEHAVIOR_PROOF", "RUNTIME_TRUSTED_BEHAVIOR_PROOF", "EXTERNAL_FACT_PROOF"] },
        "test_evidence_state": { "enum": ["COVERED", "PARTIAL", "NOT_COVERED", "BLOCKED"] },
        "assurance_state": { "enum": ["ASSURED", "BLOCKED_MISSING_TEST_EVIDENCE", "BLOCKED_WEAK_PROOF", "BLOCKED_SOURCE_MISMATCH"] }
      }
    },
    "runtimeTrustBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement", "status", "run_manifest_ref", "run_manifest_digest", "run_id", "task_ref",
        "intent_digest", "runtime_trust_level", "runtime_plan_ref", "runtime_plan_digest",
        "lifecycle_plan_ref", "lifecycle_plan_digest", "verification_plan_ref", "verification_plan_digest",
        "current_project_match", "current_task_match", "current_intent_match",
        "current_verification_plan_match", "checker", "reason"
      ],
      "properties": {
        "requirement": { "enum": ["REQUIRED", "NOT_REQUIRED"] },
        "status": { "enum": ["VERIFIED", "BLOCKED", "NOT_REQUIRED"] },
        "run_manifest_ref": { "type": "string", "minLength": 1 },
        "run_manifest_digest": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 },
        "task_ref": { "type": "string", "minLength": 1 },
        "intent_digest": { "type": "string", "minLength": 1 },
        "runtime_trust_level": { "type": "string", "minLength": 1 },
        "runtime_plan_ref": { "type": "string", "minLength": 1 },
        "runtime_plan_digest": { "type": "string", "minLength": 1 },
        "lifecycle_plan_ref": { "type": "string", "minLength": 1 },
        "lifecycle_plan_digest": { "type": "string", "minLength": 1 },
        "verification_plan_ref": { "type": "string", "minLength": 1 },
        "verification_plan_digest": { "type": "string", "minLength": 1 },
        "current_project_match": { "enum": ["Yes", "No", "Unknown", "N/A"] },
        "current_task_match": { "enum": ["Yes", "No", "Unknown", "N/A"] },
        "current_intent_match": { "enum": ["Yes", "No", "Unknown", "N/A"] },
        "current_verification_plan_match": { "enum": ["Yes", "No", "Unknown", "N/A"] },
        "checker": { "enum": ["scripts/check-verification-run-manifest.mjs --require-complete", "N/A"] },
        "reason": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "requirement": { "const": "NOT_REQUIRED" } }, "required": ["requirement"] },
          "then": {
            "properties": {
              "status": { "const": "NOT_REQUIRED" },
              "run_manifest_ref": { "const": "N/A" },
              "run_manifest_digest": { "const": "N/A" },
              "run_id": { "const": "N/A" },
              "task_ref": { "const": "N/A" },
              "intent_digest": { "const": "N/A" },
              "runtime_trust_level": { "const": "N/A" },
              "runtime_plan_ref": { "const": "N/A" },
              "runtime_plan_digest": { "const": "N/A" },
              "lifecycle_plan_ref": { "const": "N/A" },
              "lifecycle_plan_digest": { "const": "N/A" },
              "verification_plan_ref": { "const": "N/A" },
              "verification_plan_digest": { "const": "N/A" },
              "current_project_match": { "const": "N/A" },
              "current_task_match": { "const": "N/A" },
              "current_intent_match": { "const": "N/A" },
              "current_verification_plan_match": { "const": "N/A" },
              "checker": { "const": "N/A" }
            }
          },
          "else": {
            "properties": {
              "status": { "enum": ["VERIFIED", "BLOCKED"] },
              "checker": { "const": "scripts/check-verification-run-manifest.mjs --require-complete" }
            }
          }
        }
      ]
    },
    "authorityBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding_version", "project", "task", "sources"],
      "properties": {
        "binding_version": { "const": "1.91.0" },
        "project": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "fingerprint", "revision"],
          "properties": {
            "kind": { "enum": ["GIT", "NON_GIT"] },
            "fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
            "revision": { "type": "string", "minLength": 1 }
          }
        },
        "task": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_ref", "intent_digest"],
          "properties": {
            "task_ref": { "type": "string", "minLength": 1 },
            "intent_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref", "relative_path", "raw_file_digest"],
            "properties": {
              "ref": { "type": "string", "minLength": 1 },
              "relative_path": { "type": "string", "minLength": 1 },
              "raw_file_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
            }
          }
        }
      }
    },
    "assuranceState": {
      "enum": [
        "VERIFIED_DONE",
        "PARTIAL_DONE",
        "BLOCKED_BY_MISSING_EVIDENCE",
        "BLOCKED_BY_UNEXPECTED_DIFF",
        "BLOCKED_BY_PATCH_SMELL",
        "BLOCKED_BY_SCOPE_DRIFT",
        "BLOCKED_BY_RISK",
        "NEEDS_HUMAN_DECISION"
      ]
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "evidence_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "DONE",
            "PENDING",
            "BLOCKED",
            "OUT_OF_SCOPE_WITH_REASON"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "expected",
        "status",
        "evidence_refs"
      ],
      "properties": {
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "expected": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "status": {
          "enum": [
            "DONE",
            "PENDING",
            "BLOCKED",
            "OUT_OF_SCOPE_WITH_REASON"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidenceBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion_id",
        "evidence_ref",
        "resolved",
        "current_task_match"
      ],
      "properties": {
        "criterion_id": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "resolved": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "current_task_match": {
          "enum": [
            "Yes",
            "No"
          ]
        }
      }
    },
    "sourceSystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "ref",
        "contribution",
        "source_system_ref",
        "source_task_ref",
        "source_outcome",
        "current_task_match"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "RECORDED",
            "NEEDS_INPUT",
            "BLOCKED"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "contribution": {
          "type": "string",
          "minLength": 1
        },
        "source_system_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_task_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_outcome": {
          "type": "string",
          "minLength": 1
        },
        "current_task_match": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "report_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "evidence_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "taskEntryBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_queue_item_ref",
        "work_queue_item_digest",
        "work_queue_item_state",
        "work_queue_item_current_task_match",
        "approved_resume_review",
        "task_governance_ref",
        "task_governance_digest",
        "task_governance_tier",
        "task_governance_review_level",
        "task_governance_task_match",
        "minimal_verification_status",
        "targeted_verification_status",
        "high_impact_evidence_chain_complete",
        "task_governance_blocks_completion",
        "tier_completion_requirements_satisfied",
        "unresolved_task_governance_blockers",
        "plain_user_blocker"
      ],
      "properties": {
        "work_queue_item_ref": {
          "type": "string",
          "minLength": 1
        },
        "work_queue_item_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "work_queue_item_state": {
          "enum": [
            "CURRENT",
            "PAUSED",
            "BLOCKED",
            "BACKLOG",
            "DONE",
            "CANCELLED"
          ]
        },
        "work_queue_item_current_task_match": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "approved_resume_review": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "resume_review_ref": {
          "type": "string"
        },
        "resume_review_digest": {
          "type": "string"
        },
        "resume_review_owner": {
          "type": "string"
        },
        "resume_review_task_match": {
          "enum": [
            "Yes",
            "No",
            "N/A"
          ]
        },
        "task_governance_ref": {
          "type": "string",
          "minLength": 1
        },
        "task_governance_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "task_governance_tier": {
          "enum": [
            "LOW",
            "MEDIUM",
            "POSSIBLE_HIGH",
            "HIGH"
          ]
        },
        "task_governance_review_level": {
          "enum": [
            "LIGHTWEIGHT",
            "TARGETED",
            "BLOCKING_CLARIFICATION",
            "FULL"
          ]
        },
        "task_governance_task_match": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "minimal_verification_status": {
          "enum": [
            "REQUIRED",
            "NOT_RUN",
            "RECORDED",
            "NOT_APPLICABLE_WITH_REASON",
            "N/A"
          ]
        },
        "targeted_verification_status": {
          "enum": [
            "REQUIRED",
            "NOT_RUN",
            "RECORDED",
            "NOT_APPLICABLE_WITH_REASON",
            "N/A"
          ]
        },
        "high_impact_evidence_chain_complete": {
          "enum": [
            "Yes",
            "No",
            "N/A"
          ]
        },
        "task_governance_blocks_completion": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "tier_completion_requirements_satisfied": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "unresolved_task_governance_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "plain_user_blocker": {
          "type": "string"
        }
      }
    }
  }
}
