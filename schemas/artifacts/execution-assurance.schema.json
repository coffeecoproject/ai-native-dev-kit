{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coffeecoproject.dev/schemas/execution-assurance.schema.json",
  "title": "Execution Assurance Report Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "execution_kind",
    "task_ref",
    "intent_digest",
    "assurance_state",
    "can_claim_done",
    "can_codex_write_now",
    "intent_lock",
    "completion_contract",
    "planned_impact_map",
    "execution_plan",
    "actual_diff",
    "evidence_bindings",
    "review",
    "patch_assessment",
    "source_systems",
    "pending_human_decisions",
    "forbidden_claims",
    "boundary",
    "outcome"
  ],
  "properties": {
    "schema_version": { "const": "1.74.0" },
    "artifact_type": { "const": "execution_assurance_report" },
    "execution_kind": {
      "enum": [
        "FEATURE_IMPLEMENTATION",
        "BUG_FIX",
        "SAFE_PATCH",
        "CONTROLLED_PATCH",
        "ADOPTION_MIGRATION",
        "BASELINE_SETUP",
        "DOCUMENT_GOVERNANCE",
        "RELEASE_PREPARATION",
        "WORKFLOW_CAPABILITY",
        "UNKNOWN"
      ]
    },
    "task_ref": { "type": "string", "minLength": 1 },
    "intent_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "assurance_state": { "$ref": "#/$defs/assuranceState" },
    "can_claim_done": { "enum": ["Yes", "No"] },
    "can_codex_write_now": { "const": "No" },
    "intent_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_intent", "normalized_intent", "in_scope", "out_of_scope"],
      "properties": {
        "user_intent": { "type": "string", "minLength": 1 },
        "normalized_intent": { "type": "string", "minLength": 1 },
        "in_scope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } }
      }
    },
    "completion_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criteria"],
      "properties": {
        "criteria": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/criterion" } }
      }
    },
    "planned_impact_map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surfaces"],
      "properties": {
        "surfaces": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/surface" } }
      }
    },
    "execution_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan_ref", "planned_target_paths", "risk_classification", "approval_refs", "restore_strategy"],
      "properties": {
        "plan_ref": { "type": "string", "minLength": 1 },
        "planned_target_paths": { "type": "array", "items": { "type": "string" } },
        "risk_classification": { "type": "string", "minLength": 1 },
        "approval_refs": { "type": "array", "items": { "type": "string" } },
        "restore_strategy": { "type": "string", "minLength": 1 }
      }
    },
    "actual_diff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diff_source", "changed_files", "unexpected_files", "target_diff_status"],
      "properties": {
        "diff_source": { "type": "string", "minLength": 1 },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "unexpected_files": { "type": "array", "items": { "type": "string" } },
        "target_diff_status": {
          "enum": [
            "MATCHED_PLAN",
            "REQUIRES_EXPLICIT_EXECUTION_PLAN",
            "UNCHANGED_FOR_READ_ONLY",
            "UNCHANGED_FOR_READ_ONLY_OR_MATCHED_FOR_WRITE",
            "UNEXPECTED_DIFF",
            "UNKNOWN"
          ]
        }
      }
    },
    "evidence_bindings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidenceBinding" }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_required", "review_refs", "all_reviewers_closed"],
      "properties": {
        "review_required": { "enum": ["Yes", "No"] },
        "review_refs": { "type": "array", "items": { "type": "string" } },
        "all_reviewers_closed": { "enum": ["Yes", "No"] }
      }
    },
    "patch_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reason"],
      "properties": {
        "state": { "enum": ["NOT_A_PATCH", "SAFE_PATCH", "CONTROLLED_PATCH", "PATCH_SMELL", "BLOCKED_PATCH"] },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "source_systems": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceSystem" }
    },
    "task_entry_binding": { "$ref": "#/$defs/taskEntryBinding" },
    "pending_human_decisions": { "type": "array", "items": { "type": "string" } },
    "forbidden_claims": { "type": "array", "items": { "type": "string" } },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writes_target_files",
        "authorizes_target_file_writes",
        "approves_implementation_beyond_recorded_scope",
        "approves_commit_or_push",
        "approves_release_or_production",
        "replaces_source_systems",
        "proves_product_correctness",
        "transfers_project_authority_to_intentos"
      ],
      "properties": {
        "writes_target_files": { "const": "No" },
        "authorizes_target_file_writes": { "const": "No" },
        "approves_implementation_beyond_recorded_scope": { "const": "No" },
        "approves_commit_or_push": { "const": "No" },
        "approves_release_or_production": { "const": "No" },
        "replaces_source_systems": { "const": "No" },
        "proves_product_correctness": { "const": "No" },
        "transfers_project_authority_to_intentos": { "const": "No" }
      }
    },
    "outcome": { "$ref": "#/$defs/assuranceState" }
  },
  "$defs": {
    "assuranceState": {
      "enum": [
        "VERIFIED_DONE",
        "PARTIAL_DONE",
        "BLOCKED_BY_MISSING_EVIDENCE",
        "BLOCKED_BY_UNEXPECTED_DIFF",
        "BLOCKED_BY_PATCH_SMELL",
        "BLOCKED_BY_SCOPE_DRIFT",
        "BLOCKED_BY_RISK",
        "NEEDS_HUMAN_DECISION"
      ]
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "evidence_refs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["DONE", "PENDING", "BLOCKED", "OUT_OF_SCOPE_WITH_REASON"] },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "expected", "status", "evidence_refs"],
      "properties": {
        "surface": { "type": "string", "minLength": 1 },
        "expected": { "enum": ["Yes", "No"] },
        "status": { "enum": ["DONE", "PENDING", "BLOCKED", "OUT_OF_SCOPE_WITH_REASON"] },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidenceBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion_id", "evidence_ref", "resolved", "current_task_match"],
      "properties": {
        "criterion_id": { "type": "string", "minLength": 1 },
        "evidence_ref": { "type": "string", "minLength": 1 },
        "resolved": { "enum": ["Yes", "No"] },
        "current_task_match": { "enum": ["Yes", "No"] }
      }
    },
    "sourceSystem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "ref",
        "contribution",
        "source_system_ref",
        "source_task_ref",
        "source_outcome",
        "current_task_match"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["RECORDED", "NEEDS_INPUT", "BLOCKED"] },
        "ref": { "type": "string", "minLength": 1 },
        "contribution": { "type": "string", "minLength": 1 },
        "source_system_ref": { "type": "string", "minLength": 1 },
        "source_task_ref": { "type": "string", "minLength": 1 },
        "source_outcome": { "type": "string", "minLength": 1 },
        "current_task_match": { "enum": ["Yes", "No"] },
        "report_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "evidence_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "taskEntryBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_queue_item_ref",
        "work_queue_item_digest",
        "work_queue_item_state",
        "work_queue_item_current_task_match",
        "approved_resume_review",
        "task_governance_ref",
        "task_governance_digest",
        "task_governance_tier",
        "task_governance_review_level",
        "task_governance_task_match",
        "minimal_verification_status",
        "targeted_verification_status",
        "high_impact_evidence_chain_complete",
        "task_governance_blocks_completion",
        "tier_completion_requirements_satisfied",
        "unresolved_task_governance_blockers",
        "plain_user_blocker"
      ],
      "properties": {
        "work_queue_item_ref": { "type": "string", "minLength": 1 },
        "work_queue_item_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "work_queue_item_state": { "enum": ["CURRENT", "PAUSED", "BLOCKED", "BACKLOG", "DONE", "CANCELLED"] },
        "work_queue_item_current_task_match": { "enum": ["Yes", "No"] },
        "approved_resume_review": { "enum": ["Yes", "No"] },
        "resume_review_ref": { "type": "string" },
        "resume_review_digest": { "type": "string" },
        "resume_review_owner": { "type": "string" },
        "resume_review_task_match": { "enum": ["Yes", "No", "N/A"] },
        "task_governance_ref": { "type": "string", "minLength": 1 },
        "task_governance_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "task_governance_tier": { "enum": ["LOW", "MEDIUM", "POSSIBLE_HIGH", "HIGH"] },
        "task_governance_review_level": { "enum": ["LIGHTWEIGHT", "TARGETED", "BLOCKING_CLARIFICATION", "FULL"] },
        "task_governance_task_match": { "enum": ["Yes", "No"] },
        "minimal_verification_status": { "enum": ["REQUIRED", "NOT_RUN", "RECORDED", "NOT_APPLICABLE_WITH_REASON", "N/A"] },
        "targeted_verification_status": { "enum": ["REQUIRED", "NOT_RUN", "RECORDED", "NOT_APPLICABLE_WITH_REASON", "N/A"] },
        "high_impact_evidence_chain_complete": { "enum": ["Yes", "No", "N/A"] },
        "task_governance_blocks_completion": { "enum": ["Yes", "No"] },
        "tier_completion_requirements_satisfied": { "enum": ["Yes", "No"] },
        "unresolved_task_governance_blockers": { "type": "array", "items": { "type": "string" } },
        "plain_user_blocker": { "type": "string" }
      }
    }
  }
}
