{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coffeecoproject.dev/schemas/release-evidence-gate.schema.json",
  "title": "Release Evidence Gate Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "intent",
    "intent_digest",
    "release_evidence_digest",
    "release_target",
    "release_scope",
    "gate_state",
    "can_handoff_to_release_owner",
    "release_or_production_approved",
    "source_chain",
    "release_target_requirements",
    "required_evidence",
    "missing_evidence",
    "owner_decisions",
    "runtime_readiness",
    "rollback_readiness",
    "monitoring_readiness",
    "environment_readiness",
    "data_migration_readiness",
    "cost_quota_readiness",
    "existing_release_rule_mapping",
    "forbidden_actions",
    "boundaries",
    "next_step"
  ],
  "properties": {
    "schema_version": { "const": "1.80.0" },
    "artifact_type": { "const": "release_evidence_gate" },
    "intent": { "type": "string", "minLength": 1 },
    "intent_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "release_evidence_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "release_target": {
      "enum": [
        "preview",
        "internal_trial",
        "staging",
        "production_review",
        "app_store_review",
        "mini_program_review",
        "unknown"
      ]
    },
    "release_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_candidate_ref",
        "release_candidate_digest",
        "source_revision",
        "dirty_worktree_status",
        "included_task_refs",
        "included_completion_evidence_refs",
        "excluded_known_items",
        "build_artifact_ref",
        "build_artifact_digest"
      ],
      "properties": {
        "release_candidate_ref": { "type": "string", "minLength": 1 },
        "release_candidate_digest": { "type": "string" },
        "source_revision": { "type": "string", "minLength": 1 },
        "dirty_worktree_status": { "enum": ["clean", "dirty", "unknown"] },
        "included_task_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "included_completion_evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excluded_known_items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "build_artifact_ref": { "type": "string" },
        "build_artifact_digest": { "type": "string" }
      }
    },
    "gate_state": {
      "enum": [
        "NOT_READY_FOR_RELEASE_REVIEW",
        "READY_FOR_INTERNAL_TRIAL_REVIEW",
        "READY_FOR_RELEASE_OWNER_REVIEW",
        "BLOCKED_BY_MISSING_RELEASE_EVIDENCE",
        "BLOCKED_BY_HUMAN_RELEASE_DECISION",
        "OUT_OF_SCOPE_FOR_RELEASE_GATE"
      ]
    },
    "can_handoff_to_release_owner": { "enum": ["Yes", "No"] },
    "release_or_production_approved": { "const": "No" },
    "source_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "ref", "digest", "source_outcome", "current_release_match", "reason"],
        "properties": {
          "name": {
            "enum": [
              "completion_evidence",
              "test_evidence",
              "execution_assurance",
              "product_completeness",
              "launch_review_view",
              "release_plan",
              "platform_release_recipe",
              "release_handoff_pack",
              "existing_release_rule",
              "human_decision"
            ]
          },
          "status": { "enum": ["RECORDED", "NOT_PROVIDED", "UNRESOLVED", "INVALID", "OPTIONAL"] },
          "ref": { "type": "string" },
          "digest": { "type": "string" },
          "source_outcome": { "type": "string" },
          "current_release_match": { "enum": ["Yes", "No", "Unknown", "N/A"] },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "release_target_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "required_evidence_ids"],
        "properties": {
          "target": { "type": "string", "minLength": 1 },
          "required_evidence_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "required_evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing_evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "owner_decisions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "runtime_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_smoke_ref", "runtime_smoke_evidence_type", "runtime_smoke_user_note_only"],
      "properties": {
        "runtime_smoke_ref": { "type": "string" },
        "runtime_smoke_evidence_type": { "enum": ["artifact", "command-output", "manual-report", "missing", "not_applicable"] },
        "runtime_smoke_user_note_only": { "enum": ["Yes", "No"] }
      }
    },
    "rollback_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rollback_ref", "rollback_window", "blocked_by_missing_rollback"],
      "properties": {
        "rollback_ref": { "type": "string" },
        "rollback_window": { "enum": ["defined", "missing", "not_applicable"] },
        "blocked_by_missing_rollback": { "enum": ["Yes", "No"] }
      }
    },
    "monitoring_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["monitoring_ref", "incident_owner_ref", "support_handoff_ref", "blocked_by_missing_monitoring"],
      "properties": {
        "monitoring_ref": { "type": "string" },
        "incident_owner_ref": { "type": "string" },
        "support_handoff_ref": { "type": "string" },
        "blocked_by_missing_monitoring": { "enum": ["Yes", "No"] }
      }
    },
    "environment_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_environment",
        "config_owner",
        "secrets_required",
        "secrets_values_recorded",
        "dns_or_callback_changes_required",
        "blocked_by_environment_config"
      ],
      "properties": {
        "target_environment": { "enum": ["preview", "staging", "production-like", "unknown"] },
        "config_owner": { "type": "string" },
        "secrets_required": { "enum": ["Yes", "No", "Unknown"] },
        "secrets_values_recorded": { "const": "No" },
        "dns_or_callback_changes_required": { "enum": ["Yes", "No", "Unknown"] },
        "blocked_by_environment_config": { "enum": ["Yes", "No"] }
      }
    },
    "data_migration_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["migration_required", "migration_plan_ref", "backup_or_restore_ref", "data_owner_ref", "codex_may_execute_migration"],
      "properties": {
        "migration_required": { "enum": ["Yes", "No", "Unknown"] },
        "migration_plan_ref": { "type": "string" },
        "backup_or_restore_ref": { "type": "string" },
        "data_owner_ref": { "type": "string" },
        "codex_may_execute_migration": { "const": "No" }
      }
    },
    "cost_quota_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cost_owner_ref", "quota_risks", "blocked_by_unknown_quota"],
      "properties": {
        "cost_owner_ref": { "type": "string" },
        "quota_risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocked_by_unknown_quota": { "enum": ["Yes", "No"] }
      }
    },
    "existing_release_rule_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project_rule_ref", "intentos_requirement", "mapping_state"],
        "properties": {
          "project_rule_ref": { "type": "string" },
          "intentos_requirement": { "type": "string", "minLength": 1 },
          "mapping_state": {
            "enum": ["PROJECT_STRONGER_RULE", "PROJECT_WEAKER_RULE", "MATCHED", "MISSING", "NEEDS_OWNER", "NOT_APPLICABLE"]
          }
        }
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writes_target_files",
        "approves_release_or_production",
        "executes_deployment",
        "executes_migration",
        "uses_or_records_secrets",
        "submits_to_app_store_or_mini_program",
        "changes_dns_payment_provider_or_ci",
        "proves_real_user_stability"
      ],
      "properties": {
        "writes_target_files": { "const": "No" },
        "approves_release_or_production": { "const": "No" },
        "executes_deployment": { "const": "No" },
        "executes_migration": { "const": "No" },
        "uses_or_records_secrets": { "const": "No" },
        "submits_to_app_store_or_mini_program": { "const": "No" },
        "changes_dns_payment_provider_or_ci": { "const": "No" },
        "proves_real_user_stability": { "const": "No" }
      }
    },
    "next_step": { "type": "string", "minLength": 1 }
  }
}
