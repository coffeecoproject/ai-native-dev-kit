{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coffeecoproject.dev/schemas/behavioral-adoption-activation.schema.json",
  "title": "Behavioral Adoption Activation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "project_binding", "goal_digest", "apply_receipt", "cold_start", "route_calibration", "activation_state", "first_task_state", "first_task", "blockers", "boundaries", "outcome", "activation_digest"],
  "properties": {
    "schema_version": { "const": "1.109.0" },
    "artifact_type": { "const": "behavioral_adoption_activation" },
    "project_binding": { "type": "object", "minProperties": 1 },
    "goal_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "apply_receipt": { "$ref": "#/$defs/source" },
    "cold_start": { "$ref": "#/$defs/source" },
    "route_calibration": { "$ref": "#/$defs/source" },
    "activation_state": { "enum": ["VERIFIED_ACTIVE", "BLOCKED"] },
    "first_task_state": { "enum": ["NOT_STARTED", "VERIFIED", "BLOCKED"] },
    "first_task": { "$ref": "#/$defs/source" },
    "blockers": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "boundaries": { "type": "object" },
    "outcome": { "enum": ["VERIFIED_ACTIVE", "BLOCKED"] },
    "activation_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "digest", "state"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "pattern": "^(?:N/A|sha256:[a-f0-9]{64})$" },
        "state": { "type": "string", "minLength": 1 }
      }
    }
  }
}
