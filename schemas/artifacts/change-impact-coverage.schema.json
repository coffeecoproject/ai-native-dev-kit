{
  "schemaVersion": "1.49.0",
  "artifactType": "change_impact_coverage",
  "required": [
    "schema_version",
    "artifact_type",
    "artifact_id",
    "impact_digest",
    "mode",
    "user_request",
    "change_type",
    "changed_files",
    "affected_surface_map",
    "implementation_coverage",
    "verification_coverage",
    "missed_surface_review",
    "boundaries",
    "outcome"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.49.0", "1.108.0", "1.113.0"] },
    "artifact_type": { "type": "string", "enum": ["change_impact_coverage"] },
    "artifact_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "impact_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "task_ref": { "type": "string", "minLength": 1 },
    "intent_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "mode": { "type": "string", "enum": ["preflight", "closure"] },
    "user_request": {
      "type": "object",
      "required": ["intent", "task_ref", "project_profile"],
      "properties": {
        "intent": { "type": "string" },
        "task_ref": { "type": "string" },
        "project_profile": { "type": "string" }
      }
    },
    "business_rule_ref": { "type": "string" },
    "business_rule_digest": { "type": "string" },
    "business_rule_state": { "type": "string" },
    "business_universe_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required", "routing_result", "business_universe_ref", "business_universe_digest",
        "business_universe_state", "coverage_scenario_ids", "coverage_mapping_status"
      ],
      "properties": {
        "required": { "enum": ["Yes", "No", "Unknown"] },
        "routing_result": { "enum": ["REQUIRED_WITH_EVIDENCE", "TECHNICAL_INSPECTION_REQUIRED", "NOT_REQUIRED_WITH_REASON"] },
        "business_universe_ref": { "type": "string", "minLength": 1 },
        "business_universe_digest": { "type": "string", "minLength": 1 },
        "business_universe_state": { "type": "string", "minLength": 1 },
        "coverage_scenario_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "coverage_mapping_status": { "enum": ["COMPLETE", "NOT_REQUIRED", "BLOCKED"] }
      }
    },
    "impact_scenario_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["impact_mapping_id", "source_coverage_scenario_ids", "affected_surfaces", "mapping_state"],
        "properties": {
          "impact_mapping_id": { "type": "string", "pattern": "^impact-mapping:[a-z0-9][a-z0-9._-]*$" },
          "source_coverage_scenario_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "affected_surfaces": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "mapping_state": { "enum": ["MAPPED", "BLOCKED"] }
        }
      }
    },
    "change_type": {
      "type": "object",
      "required": ["primary_type", "risk_level", "reason"],
      "properties": {
        "primary_type": {
          "type": "string",
          "enum": [
            "DOCS_ONLY",
            "COPY_ONLY",
            "PERMISSION_OR_VISIBILITY_RULE",
            "DATA_OR_MODEL_CHANGE",
            "VALIDATION_OR_BUSINESS_RULE",
            "API_CONTRACT_CHANGE",
            "GENERAL_PRODUCT_CHANGE"
          ]
        },
        "risk_level": { "type": "string", "enum": ["low", "high"] },
        "reason": { "type": "string" }
      }
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "affected_surface_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["surface", "status", "reason", "expected_evidence"],
        "properties": {
          "surface": {
            "type": "string",
            "enum": [
              "USER_FLOW",
              "FRONTEND_UI",
              "API_CONTRACT",
              "BACKEND_RULE",
              "DATA_MODEL",
              "ERROR_COPY",
              "TEST_COVERAGE",
              "DOCS_HANDOFF",
              "PERMISSION_RISK",
              "RELEASE_IMPACT",
              "BACKGROUND_WORK",
              "EXTERNAL_INTEGRATION",
              "RUNTIME_BEHAVIOR",
              "ROLLBACK_RECOVERY"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["REQUIRED", "OPTIONAL", "NOT_APPLICABLE", "NEEDS_HUMAN_DECISION"]
          },
          "reason": { "type": "string" },
          "expected_evidence": { "type": "string" }
        }
      }
    },
    "implementation_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["surface", "status", "evidence", "reason"],
        "properties": {
          "surface": {
            "type": "string",
            "enum": [
              "USER_FLOW",
              "FRONTEND_UI",
              "API_CONTRACT",
              "BACKEND_RULE",
              "DATA_MODEL",
              "ERROR_COPY",
              "TEST_COVERAGE",
              "DOCS_HANDOFF",
              "PERMISSION_RISK",
              "RELEASE_IMPACT",
              "BACKGROUND_WORK",
              "EXTERNAL_INTEGRATION",
              "RUNTIME_BEHAVIOR",
              "ROLLBACK_RECOVERY"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["DONE", "NOT_APPLICABLE", "OUT_OF_SCOPE", "NEEDS_HUMAN_DECISION", "NOT_STARTED"]
          },
          "evidence": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "verification_coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["surface", "verification", "evidence", "status"],
        "properties": {
          "surface": {
            "type": "string",
            "enum": [
              "USER_FLOW",
              "FRONTEND_UI",
              "API_CONTRACT",
              "BACKEND_RULE",
              "DATA_MODEL",
              "ERROR_COPY",
              "TEST_COVERAGE",
              "DOCS_HANDOFF",
              "PERMISSION_RISK",
              "RELEASE_IMPACT",
              "BACKGROUND_WORK",
              "EXTERNAL_INTEGRATION",
              "RUNTIME_BEHAVIOR",
              "ROLLBACK_RECOVERY"
            ]
          },
          "verification": { "type": "string" },
          "evidence": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["DONE", "NOT_APPLICABLE", "OUT_OF_SCOPE", "NEEDS_HUMAN_DECISION", "NOT_STARTED"]
          }
        }
      }
    },
    "missed_surface_review": {
      "type": "object",
      "required": ["missed_surfaces_found", "notes"],
      "properties": {
        "missed_surfaces_found": { "type": "string", "enum": ["Yes", "No"] },
        "notes": { "type": "string" }
      }
    },
    "pending_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision_id", "decision_class", "question", "status"],
        "properties": {
          "decision_id": { "type": "string", "pattern": "^decision:[a-z0-9][a-z0-9._-]*$" },
          "decision_class": { "enum": ["BUSINESS_FACT_NEEDED", "EXTERNAL_FACT_NEEDED", "REAL_WORLD_CONSENT_NEEDED"] },
          "question": { "type": "string", "minLength": 1 },
          "status": { "const": "PENDING" }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "required": [
        "writes_target_files",
        "authorizes_implementation",
        "approves_release_or_production",
        "replaces_human_product_judgment",
        "proves_every_possible_impact_was_found"
      ],
      "properties": {
        "writes_target_files": { "type": "boolean" },
        "authorizes_implementation": { "type": "boolean" },
        "approves_release_or_production": { "type": "boolean" },
        "replaces_human_product_judgment": { "type": "boolean" },
        "proves_every_possible_impact_was_found": { "type": "boolean" }
      }
    },
    "outcome": {
      "type": "string",
      "enum": ["CHANGE_IMPACT_RECORDED", "NEEDS_HUMAN_DECISION", "BLOCKED"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "schema_version": { "const": "1.108.0" } } },
      "then": { "required": ["business_universe_binding", "impact_scenario_mappings"] }
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.113.0" } } },
      "then": { "required": ["task_ref", "intent_digest", "business_universe_binding", "impact_scenario_mappings", "pending_decisions"] }
    }
  ],
  "additionalProperties": false
}
