{
  "schemaVersion": "1.0",
  "artifactType": "task",
  "required": ["schema_version", "artifact_type", "number", "slug", "title", "spec", "eval", "task_level", "status", "created_at"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.0$" },
    "artifact_type": { "type": "string", "enum": ["task"] },
    "number": { "type": "string", "pattern": "^[0-9]{3}$" },
    "slug": { "type": "string" },
    "title": { "type": "string" },
    "spec": { "type": "string" },
    "eval": { "type": "string" },
    "task_level": { "type": "string", "enum": ["L0", "L1", "L2", "L3"] },
    "status": { "type": "string", "enum": ["draft", "ready", "implementing", "done"] },
    "created_at": { "type": "string" }
  }
}
