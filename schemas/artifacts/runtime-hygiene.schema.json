{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coffeecoproject.dev/schemas/runtime-hygiene.schema.json",
  "title": "Runtime Hygiene Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "runtime_hygiene_ref",
    "runtime_hygiene_digest",
    "task_ref",
    "work_queue_item_ref",
    "task_governance_ref",
    "operation",
    "runtime_class",
    "decision_state",
    "plain_user_summary",
    "plain_next_step",
    "technical_terms_required",
    "git_context",
    "gate_context",
    "release_context",
    "artifact_context",
    "bundle_context",
    "boundaries",
    "required_approval",
    "task_continuation",
    "outcome"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        "1.86.0",
        "1.86.1",
        "1.93.0"
      ]
    },
    "artifact_type": {
      "const": "runtime_hygiene"
    },
    "runtime_hygiene_ref": {
      "type": "string",
      "minLength": 1
    },
    "runtime_hygiene_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "task_ref": {
      "type": "string",
      "minLength": 1
    },
    "work_queue_item_ref": {
      "type": "string",
      "minLength": 1
    },
    "task_governance_ref": {
      "type": "string",
      "minLength": 1
    },
    "task_entry_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_queue_item_ref",
        "work_queue_item_digest",
        "work_queue_item_state",
        "work_queue_item_current_task_match",
        "approved_resume_review",
        "resume_review_ref",
        "resume_review_digest",
        "resume_review_owner",
        "resume_review_task_match",
        "task_governance_ref",
        "task_governance_digest",
        "task_governance_task_match",
        "task_governance_tier",
        "task_governance_review_level",
        "task_governance_blocks_completion",
        "unresolved_task_governance_blockers",
        "tier_completion_requirements_satisfied",
        "minimal_verification_status",
        "targeted_verification_status",
        "high_impact_evidence_chain_complete",
        "plain_user_blocker"
      ],
      "properties": {
        "work_queue_item_ref": {
          "type": "string",
          "minLength": 1
        },
        "work_queue_item_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "work_queue_item_state": {
          "enum": [
            "CURRENT",
            "PAUSED",
            "BLOCKED",
            "DONE",
            "UNKNOWN"
          ]
        },
        "work_queue_item_current_task_match": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "approved_resume_review": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "resume_review_ref": {
          "type": "string",
          "minLength": 1
        },
        "resume_review_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "resume_review_owner": {
          "type": "string",
          "minLength": 1
        },
        "resume_review_task_match": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "task_governance_ref": {
          "type": "string",
          "minLength": 1
        },
        "task_governance_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "task_governance_task_match": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "task_governance_tier": {
          "enum": [
            "LOW",
            "MEDIUM",
            "POSSIBLE_HIGH",
            "HIGH"
          ]
        },
        "task_governance_review_level": {
          "enum": [
            "LIGHTWEIGHT",
            "TARGETED",
            "BLOCKED_FOR_CLASSIFICATION",
            "FULL"
          ]
        },
        "task_governance_blocks_completion": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "unresolved_task_governance_blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tier_completion_requirements_satisfied": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "minimal_verification_status": {
          "enum": [
            "RECORDED",
            "NOT_APPLICABLE_WITH_REASON",
            "MISSING"
          ]
        },
        "targeted_verification_status": {
          "enum": [
            "RECORDED",
            "NOT_APPLICABLE_WITH_REASON",
            "MISSING"
          ]
        },
        "high_impact_evidence_chain_complete": {
          "enum": [
            "Yes",
            "No",
            "N/A"
          ]
        },
        "plain_user_blocker": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "operation": {
      "enum": [
        "commit",
        "push",
        "ci",
        "release",
        "artifact-cleanup",
        "bundle-slimming"
      ]
    },
    "runtime_class": {
      "enum": [
        "GIT_LINEAGE_DIRTY",
        "COMMIT_SCOPE_MIXED",
        "PRE_PUSH_GATE_FAILED",
        "STRUCTURE_BUDGET_EXCEEDED",
        "CI_CODE_FAILURE",
        "CI_ENVIRONMENT_FAILURE",
        "RELEASE_PREFLIGHT_READY",
        "RELEASE_PREFLIGHT_FAILED",
        "ARTIFACT_QUOTA_BLOCKED",
        "RELEASE_BUNDLE_OVERSIZED",
        "PRODUCTION_SIDE_EFFECT_UNKNOWN",
        "PRODUCTION_SIDE_EFFECT_PRESENT"
      ]
    },
    "decision_state": {
      "enum": [
        "CAN_CONTINUE_AUTOMATICALLY",
        "CAN_CONTINUE_AFTER_PROJECT_GATE_REPAIR",
        "CAN_CONTINUE_TO_RELEASE_REVIEW",
        "NEEDS_PLAIN_USER_APPROVAL",
        "NEEDS_RELEASE_OWNER_APPROVAL",
        "BLOCKED_BY_IRREVERSIBLE_ACTION",
        "BLOCKED_BY_PRODUCTION_SIDE_EFFECT",
        "BLOCKED_BY_UNCLEAR_TASK_SCOPE"
      ]
    },
    "plain_user_summary": {
      "type": "string",
      "minLength": 1
    },
    "plain_next_step": {
      "type": "string",
      "minLength": 1
    },
    "technical_terms_required": {
      "const": "No"
    },
    "git_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "upstream",
        "origin_main_fresh",
        "ahead_count",
        "behind_count",
        "current_task_commit_isolated",
        "force_push_required"
      ],
      "properties": {
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "upstream": {
          "type": "string",
          "minLength": 1
        },
        "origin_main_fresh": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "ahead_count": {
          "type": "integer"
        },
        "behind_count": {
          "type": "integer"
        },
        "current_task_commit_isolated": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "force_push_required": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        }
      }
    },
    "gate_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_name",
        "exit_code",
        "failure_class",
        "current_task_related",
        "bypass_recommended"
      ],
      "properties": {
        "gate_name": {
          "type": "string",
          "minLength": 1
        },
        "exit_code": {
          "type": "string",
          "minLength": 1
        },
        "failure_class": {
          "type": "string",
          "minLength": 1
        },
        "current_task_related": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "bypass_recommended": {
          "enum": [
            "Yes",
            "No"
          ]
        }
      }
    },
    "ci_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retry_policy_allowed",
        "production_side_effect_checked",
        "ci_log_ref",
        "ci_log_digest"
      ],
      "properties": {
        "retry_policy_allowed": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "production_side_effect_checked": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "ci_log_ref": {
          "type": "string",
          "minLength": 1
        },
        "ci_log_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "release_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_state",
        "production_touched",
        "release_id_reusable",
        "release_owner_required"
      ],
      "properties": {
        "lane_state": {
          "enum": [
            "PREFLIGHT_ONLY",
            "BUNDLE_CREATED",
            "TEST_LANE_STARTED",
            "PROD_FREEZE_ENTERED",
            "PROD_DEPLOY_STARTED",
            "PROD_DEPLOY_DONE",
            "UNKNOWN"
          ]
        },
        "production_touched": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "release_id_reusable": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "release_owner_required": {
          "enum": [
            "Yes",
            "No"
          ]
        }
      }
    },
    "artifact_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_quota_blocked",
        "artifact_deletion_required",
        "artifact_deletion_irreversible",
        "preserve_evidence_artifacts",
        "preserve_latest_production_bundle"
      ],
      "properties": {
        "artifact_quota_blocked": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "artifact_deletion_required": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        },
        "artifact_deletion_irreversible": {
          "enum": [
            "Yes",
            "No",
            "N/A"
          ]
        },
        "preserve_evidence_artifacts": {
          "const": "Yes"
        },
        "preserve_latest_production_bundle": {
          "enum": [
            "Yes",
            "No",
            "Unknown"
          ]
        }
      }
    },
    "bundle_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_size_status",
        "suspected_non_runtime_content",
        "evidence_removed",
        "bundle_slimming_recommended"
      ],
      "properties": {
        "bundle_size_status": {
          "enum": [
            "OK",
            "WARN",
            "BLOCKED",
            "Unknown"
          ]
        },
        "suspected_non_runtime_content": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_removed": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "bundle_slimming_recommended": {
          "enum": [
            "Yes",
            "No"
          ]
        }
      }
    },
    "runtime_source_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_kind",
          "source_ref",
          "source_digest",
          "source_present",
          "current_task_match"
        ],
        "properties": {
          "source_kind": {
            "enum": [
              "gate_output",
              "ci_log",
              "artifact_error",
              "bundle_summary",
              "release_event"
            ]
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "source_digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "source_present": {
            "enum": [
              "Yes",
              "No"
            ]
          },
          "current_task_match": {
            "enum": [
              "Yes",
              "No",
              "Unknown"
            ]
          }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writes_target_files",
        "approves_commit_or_push",
        "approves_release_or_production",
        "bypasses_gates",
        "deletes_artifacts",
        "changes_production",
        "force_pushes"
      ],
      "properties": {
        "writes_target_files": {
          "const": "No"
        },
        "approves_commit_or_push": {
          "const": "No"
        },
        "approves_release_or_production": {
          "const": "No"
        },
        "bypasses_gates": {
          "const": "No"
        },
        "deletes_artifacts": {
          "const": "No"
        },
        "changes_production": {
          "const": "No"
        },
        "force_pushes": {
          "const": "No"
        }
      }
    },
    "required_approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_required",
        "approval_reason",
        "approval_scope"
      ],
      "properties": {
        "approval_required": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "approval_reason": {
          "type": "string",
          "minLength": 1
        },
        "approval_scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "release_trust_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_candidate_ref",
        "release_candidate_digest",
        "source_revision"
      ],
      "properties": {
        "release_candidate_ref": {
          "type": "string",
          "pattern": "^(artifact|file):[^\\s]+$"
        },
        "release_candidate_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "source_revision": {
          "type": "string",
          "minLength": 1
        },
        "release_execution_topology_ref": {
          "type": "string",
          "minLength": 1
        },
        "release_execution_topology_digest": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "task_continuation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_remains_open",
        "resume_action",
        "work_queue_update_required"
      ],
      "properties": {
        "task_remains_open": {
          "enum": [
            "Yes",
            "No"
          ]
        },
        "resume_action": {
          "type": "string",
          "minLength": 1
        },
        "work_queue_update_required": {
          "enum": [
            "Yes",
            "No"
          ]
        }
      }
    },
    "outcome": {
      "enum": [
        "CAN_CONTINUE_AUTOMATICALLY",
        "CAN_CONTINUE_AFTER_PROJECT_GATE_REPAIR",
        "CAN_CONTINUE_TO_RELEASE_REVIEW",
        "NEEDS_PLAIN_USER_APPROVAL",
        "NEEDS_RELEASE_OWNER_APPROVAL",
        "BLOCKED_BY_IRREVERSIBLE_ACTION",
        "BLOCKED_BY_PRODUCTION_SIDE_EFFECT",
        "BLOCKED_BY_UNCLEAR_TASK_SCOPE"
      ]
    }
  }
}
