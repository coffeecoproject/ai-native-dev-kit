{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coffeecoproject.dev/schemas/project-entry-calibration.schema.json",
  "title": "Project Entry Calibration Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "report_ref",
    "report_digest",
    "source_revision",
    "source_before_digest",
    "source_after_digest",
    "source_unchanged",
    "observation_scope",
    "fixtures",
    "boundaries",
    "outcome"
  ],
  "properties": {
    "schema_version": { "const": "1.109.0" },
    "artifact_type": { "const": "project_entry_calibration" },
    "report_ref": { "type": "string", "pattern": "^calibration-reports/[a-zA-Z0-9._-]+\\.json$" },
    "report_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "source_revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "source_before_digest": { "$ref": "#/$defs/digest" },
    "source_after_digest": { "$ref": "#/$defs/digest" },
    "source_unchanged": { "const": "Yes" },
    "observation_scope": {
      "enum": ["PRE_IMPLEMENTATION_BASELINE", "POST_IMPLEMENTATION_ACCEPTANCE"]
    },
    "fixtures": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/fixture" }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writes_target_files",
        "imports_project_specific_facts",
        "authorizes_implementation",
        "authorizes_adoption_apply",
        "proves_acceptance"
      ],
      "properties": {
        "writes_target_files": { "const": "No" },
        "imports_project_specific_facts": { "const": "No" },
        "authorizes_implementation": { "const": "No" },
        "authorizes_adoption_apply": { "const": "No" },
        "proves_acceptance": { "enum": ["Yes", "No"] }
      }
    },
    "outcome": {
      "enum": [
        "CALIBRATION_BASELINE_RECORDED",
        "CALIBRATION_ACCEPTED",
        "CALIBRATION_BLOCKED"
      ]
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "condition",
        "observation_dimensions",
        "repository_state",
        "command_results",
        "target_before_digest",
        "target_after_digest",
        "target_unchanged",
        "expected_assertions",
        "sensitive_or_project_specific_data"
      ],
      "properties": {
        "fixture_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "condition": {
          "enum": [
            "ABSENT_TARGET",
            "LIGHT_EXISTING",
            "STRONG_GOVERNED",
            "CURRENT_WORK_PRESENT"
          ]
        },
        "observation_dimensions": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": [
              "TARGET_TOPOLOGY",
              "PROJECT_IDENTITY",
              "GUIDANCE_AUTHORITY",
              "GOVERNANCE_AUTHORITY",
              "CURRENT_WORK",
              "ENTRY_CONSISTENCY",
              "ADOPTION_ROUTE"
            ]
          }
        },
        "repository_state": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_topology", "repository_mode", "current_work", "governance_posture"],
          "properties": {
            "target_topology": { "enum": ["ABSENT_LEAF", "EMPTY_DIRECTORY", "NONEMPTY_DIRECTORY"] },
            "repository_mode": { "enum": ["NOT_PRESENT", "NON_GIT", "GIT"] },
            "current_work": { "enum": ["NONE", "PRESENT", "UNKNOWN"] },
            "governance_posture": { "enum": ["NONE", "LIGHT", "STRONG", "UNKNOWN"] }
          }
        },
        "command_results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command_id", "command", "exit_code", "output_digest", "observation_state"],
            "properties": {
              "command_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
              "command": { "type": "string", "minLength": 1 },
              "exit_code": { "type": "integer" },
              "output_digest": { "$ref": "#/$defs/digest" },
              "observation_state": { "enum": ["BASELINE_RECORDED", "EXPECTED_BLOCK", "ACCEPTED"] }
            }
          }
        },
        "target_before_digest": { "$ref": "#/$defs/digest" },
        "target_after_digest": { "$ref": "#/$defs/digest" },
        "target_unchanged": { "const": "Yes" },
        "expected_assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "sensitive_or_project_specific_data": { "const": "No" }
      }
    }
  }
}
