{
  "id": "ios-app",
  "name": "iOS App",
  "defaultTaskLevel": "L1",
  "escalationRules": [
    {
      "when": ["architecture", "persistence", "networking-contract", "permission", "background-behavior", "cross-module-state"],
      "minLevel": "L2"
    },
    {
      "when": ["signing", "entitlements", "keychain", "iap", "sensitive-permission", "destructive-migration", "app-store-release"],
      "minLevel": "L3"
    }
  ],
  "requiredDocs": [
    "docs/product-vision.md",
    "docs/engineering-principles.md",
    "docs/risk-policy.md",
    "docs/architecture.md",
    "docs/domain-model.md",
    "docs/permission-model.md",
    "docs/test-strategy.md",
    "docs/verification-matrix.md"
  ],
  "recommendedDocs": [
    "docs/ios-build-settings.md",
    "docs/ios-release-policy.md",
    "docs/privacy-data-inventory.md"
  ],
  "riskGateMappings": {
    "permission": ["permission", "personal data"],
    "keychain": ["secrets", "personal data"],
    "entitlements": ["production config"],
    "destructive-migration": ["migration", "data deletion"],
    "iap": ["value transfer"]
  },
  "requiredVerification": [
    "Swift compile/build check",
    "unit tests where present",
    "UI tests for critical flows where present",
    "simulator launch or screenshot evidence for UI changes",
    "permission/Info.plist review when permissions change"
  ],
  "verificationKeywords": ["swift", "build", "unit", "ui", "simulator", "permission", "plist"],
  "verifyScriptKeywords": ["xcodebuild", "test"],
  "highRiskKeywords": ["signing", "entitlements", "keychain", "permission", "migration", "release"],
  "humanApprovalRequiredFor": [
    "signing",
    "entitlements",
    "keychain",
    "sensitive-permission",
    "iap",
    "destructive-migration",
    "app-store-release"
  ],
  "releaseChecks": [
    "signing, entitlements, Info.plist, and privacy strings reviewed when touched",
    "simulator or device launch evidence captured for UI and runtime changes",
    "App Store, TestFlight, IAP, and provisioning actions require human approval"
  ],
  "aiBoundaries": {
    "may": [
      "edit Swift, SwiftUI, UIKit, tests, previews, and documentation inside approved task scope",
      "diagnose build and simulator failures from local evidence"
    ],
    "mustNot": [
      "change signing credentials, provisioning profiles, entitlements, IAP, or App Store release behavior without human approval",
      "handle secrets, Keychain policy, sensitive permissions, or destructive migrations without human approval"
    ]
  },
  "compatibleStarters": ["generic-project", "codex-ios-app"]
}
